---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { label: '首页', href: base || '/' },
  { label: '文章', href: `${base}/#articles` },
];
---

<header class="sticky top-0 z-50 border-b border-ink-200 bg-white/90 backdrop-blur-md shadow-sm">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex h-15 items-center justify-between py-3">
      <a href={base || '/'} class="flex items-center gap-2.5">
        <div class="flex h-7 w-7 items-center justify-center rounded bg-brand-900">
          <svg class="h-4 w-4 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
          </svg>
        </div>
        <span class="font-bold text-brand-900 text-lg tracking-tight">投资思考</span>
        <span class="hidden sm:inline text-ink-400 text-sm font-light">/ 逻辑与数据驱动</span>
      </a>

      <nav class="flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="rounded-md px-3 py-1.5 text-sm font-medium text-ink-600 transition-colors hover:bg-brand-50 hover:text-brand-700"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
