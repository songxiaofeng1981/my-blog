---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.date);
---

<article class="group relative flex flex-col rounded-xl border border-ink-200 bg-white p-6 shadow-sm transition-all duration-200 hover:border-brand-300 hover:shadow-md">
  {post.data.tags.length > 0 && (
    <div class="relative z-10 mb-3 flex flex-wrap gap-1.5">
      {post.data.tags.map(tag => (
        <a
          href={`${base}/tags/${tag}`}
          class="rounded-md bg-gold-50 px-2 py-0.5 text-xs font-medium text-gold-700 ring-1 ring-gold-200 transition-colors hover:bg-gold-100 hover:text-gold-800"
        >
          {tag}
        </a>
      ))}
    </div>
  )}

  <h2 class="mb-2 text-lg font-bold leading-snug text-ink-900 group-hover:text-brand-700 transition-colors sm:text-xl">
    <a href={`${base}/posts/${post.slug}`} class="before:absolute before:inset-0">
      {post.data.title}
    </a>
  </h2>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-ink-500">
    {post.data.description}
  </p>

  <div class="flex items-center justify-between pt-3 border-t border-ink-100">
    <time datetime={post.data.date.toISOString()} class="text-xs text-ink-400">
      {formattedDate}
    </time>
    <span class="text-xs font-medium text-brand-600 group-hover:text-brand-500 transition-colors">
      阅读全文 &rarr;
    </span>
  </div>
</article>
