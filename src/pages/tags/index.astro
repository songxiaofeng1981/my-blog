---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const tagMap = new Map<string, number>();
allPosts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getTagClasses(count: number): string {
  if (count >= 16) return 'text-2xl font-bold text-brand-900';
  if (count >= 8)  return 'text-xl font-semibold text-brand-700';
  if (count >= 4)  return 'text-lg font-medium text-brand-600';
  if (count >= 2)  return 'text-base text-ink-700';
  return 'text-sm text-ink-400';
}
---

<BaseLayout title="标签">
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gold-600">Tags</h2>
          <h1 class="mt-1 text-2xl font-bold text-brand-900 sm:text-3xl">标签云</h1>
          <p class="mt-2 text-sm text-ink-400">共 {tags.length} 个标签，{allPosts.length} 篇文章</p>
        </div>
        <button
          id="sort-toggle"
          class="rounded-lg border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-600 transition-colors hover:border-brand-300 hover:text-brand-700"
        >
          按名称排序
        </button>
      </div>

      <div id="tag-cloud" class="flex flex-wrap gap-3">
        {tags.map(tag => (
          <a
            href={`${base}/tags/${tag.name}`}
            data-name={tag.name}
            data-count={tag.count}
            class:list={[
              'inline-flex items-center gap-1.5 min-h-[2.75rem] rounded-lg px-3 py-2 transition-colors hover:bg-brand-50 hover:ring-1 hover:ring-brand-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600',
              getTagClasses(tag.count),
            ]}
          >
            {tag.name}
            <span class="text-xs font-normal text-ink-400">({tag.count})</span>
          </a>
        ))}
      </div>

      {tags.length === 0 && (
        <div class="rounded-xl border border-ink-200 bg-white p-12 text-center">
          <p class="text-ink-400">暂无标签。</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const cloud = document.getElementById('tag-cloud')!;
  const btn = document.getElementById('sort-toggle')!;
  let sortByCount = localStorage.getItem('tag-sort') !== 'name';

  function applySort() {
    const items = Array.from(cloud.children) as HTMLElement[];
    items.sort((a, b) => {
      if (sortByCount) {
        return Number(b.dataset.count) - Number(a.dataset.count);
      }
      return (a.dataset.name || '').localeCompare(b.dataset.name || '', 'zh-CN');
    });
    items.forEach(item => cloud.appendChild(item));
    btn.textContent = sortByCount ? '按名称排序' : '按热度排序';
  }

  btn.addEventListener('click', () => {
    sortByCount = !sortByCount;
    localStorage.setItem('tag-sort', sortByCount ? 'count' : 'name');
    applySort();
  });

  applySort();
</script>
