---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateZh } from '../../utils/date';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const tagMap = new Map<string, typeof allPosts>();
  allPosts.forEach(post => {
    post.data.tags.forEach(tag => {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    });
  });

  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const showSearch = posts.length > 30;
---

<BaseLayout title={`标签：${tag}`}>
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <a
        href={`${base}/tags`}
        class="mb-8 inline-flex items-center gap-1.5 text-sm text-ink-400 transition-colors hover:text-brand-700"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        所有标签
      </a>

      <div class="mb-8">
        <h1 class="text-2xl font-bold text-brand-900 sm:text-3xl">
          <span class="text-gold-600">#</span> {tag}
        </h1>
        <p class="mt-2 text-sm text-ink-400">共 {posts.length} 篇文章</p>
      </div>

      {showSearch && (
        <div class="mb-6">
          <input
            id="search-input"
            type="text"
            placeholder="搜索文章标题…"
            class="w-full rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm text-ink-800 placeholder:text-ink-400 transition-colors focus:border-brand-300 focus:outline-none focus:ring-2 focus:ring-brand-100"
          />
        </div>
      )}

      {posts.length === 0 ? (
        <div class="rounded-xl border border-ink-200 bg-white p-12 text-center">
          <p class="text-ink-400">该标签下暂无文章。</p>
        </div>
      ) : (
        <div id="article-list" class="space-y-4">
          {posts.map(post => (
            <article class="group rounded-xl border border-ink-200 bg-white p-5 shadow-sm transition-all hover:border-brand-300 hover:shadow-md" data-title={post.data.title}>
              <div class="flex flex-wrap items-center gap-1.5 mb-2">
                {post.data.tags
                  .filter(t => t !== tag)
                  .map(t => (
                    <a
                      href={`${base}/tags/${t}`}
                      class="relative z-10 rounded-md bg-gold-50 px-2 py-0.5 text-xs font-medium text-gold-700 ring-1 ring-gold-200 transition-colors hover:bg-gold-100 hover:text-gold-800"
                    >
                      {t}
                    </a>
                  ))}
              </div>

              <h2 class="mb-2 text-lg font-bold leading-snug text-ink-900 group-hover:text-brand-700 transition-colors">
                <a href={`${base}/posts/${post.slug}`}>
                  {post.data.title}
                </a>
              </h2>

              <p class="mb-3 text-sm leading-relaxed text-ink-500 line-clamp-2">
                {post.data.description}
              </p>

              <time datetime={post.data.date.toISOString()} class="text-xs text-ink-400">
                {formatDateZh(post.data.date)}
              </time>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

{showSearch && (
  <script>
    const input = document.getElementById('search-input') as HTMLInputElement;
    const articles = document.querySelectorAll('#article-list article');

    input.addEventListener('input', () => {
      const query = input.value.toLowerCase();
      articles.forEach(article => {
        const title = (article as HTMLElement).dataset.title?.toLowerCase() || '';
        (article as HTMLElement).style.display = title.includes(query) ? '' : 'none';
      });
    });
  </script>
)}
