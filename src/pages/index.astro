---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="首页">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-ink-200 bg-white py-20 sm:py-28">
    <div class="absolute inset-0 -z-10"
      style="background-image: radial-gradient(circle at 15% 60%, #dce8ff44 0%, transparent 55%), radial-gradient(circle at 85% 20%, #fef3c744 0%, transparent 50%);">
    </div>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 text-center">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold text-brand-700 tracking-wide">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-600"></span>
        产业链时滞套利者的思考笔记
      </div>

      <h1 class="mt-4 text-4xl font-bold tracking-tight text-brand-900 sm:text-5xl lg:text-6xl">
        在错配中下注<br />
        <span class="text-gold-600">用逻辑定进出</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink-500 sm:text-lg">
        在市场错配中下注，以认知深度持有，用逻辑而非时间决定进出。这里记录投资框架、产业链研究与交易复盘。
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="#articles"
          class="rounded-lg bg-brand-900 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-brand-800 hover:shadow-md"
        >
          浏览文章
        </a>
        <a
          href="#philosophy"
          class="rounded-lg border border-ink-200 bg-white px-6 py-2.5 text-sm font-medium text-ink-600 transition-colors hover:border-brand-300 hover:text-brand-700"
        >
          投资理念
        </a>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section id="philosophy" class="border-b border-ink-200 bg-[#f7f6f2] py-24 sm:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="mb-1 text-center text-xs font-semibold uppercase tracking-widest text-gold-600">
        Investment Philosophy
      </h2>
      <h3 class="mb-16 text-center text-2xl font-bold text-brand-900 sm:text-3xl">核心投资理念</h3>

      <div class="mx-auto max-w-2xl space-y-10 text-center text-brand-900 text-xl leading-[1.85] sm:text-[1.35rem]">
        <p>
          市场定价基于共识，<br class="hidden sm:inline" />
          超额收益来自共识之外的结构性失衡。
        </p>
        <p>
          找到失衡，在下跌时敢加仓，在证伪时能离场。
        </p>
        <p>
          持有期不是目标，<span class="text-gold-600 font-semibold">逻辑窗口</span>才是。
        </p>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section id="articles" class="py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gold-600">Latest Posts</h2>
          <h3 class="mt-1 text-2xl font-bold text-brand-900 sm:text-3xl">最新文章</h3>
        </div>
        <span class="text-sm text-ink-400">{posts.length} 篇</span>
      </div>

      {posts.length === 0 ? (
        <div class="rounded-xl border border-ink-200 bg-white p-12 text-center">
          <p class="text-ink-400">文章准备中，敬请期待。</p>
        </div>
      ) : (
        <div class="grid gap-5 sm:grid-cols-2">
          {posts.map(post => <ArticleCard post={post} />)}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
